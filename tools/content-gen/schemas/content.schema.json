{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DevPath MD2 Approved Learning Content",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "title",
    "track",
    "level",
    "contentMd",
    "estimatedMinutes",
    "difficulty",
    "bloomLevel",
    "conceptTags",
    "status"
  ],
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 1 },
    "track": {
      "type": "string",
      "enum": ["BACKEND_SPRING", "FRONTEND_REACT", "MOBILE_FLUTTER", "DEVOPS", "FULLSTACK"]
    },
    "level": { "type": "string", "enum": ["INTRO", "INTERMEDIATE", "ADVANCED"] },
    "contentMd": { "type": "string", "minLength": 1 },
    "estimatedMinutes": { "type": "integer", "minimum": 1 },
    "difficulty": { "type": "number", "minimum": 0, "maximum": 1 },
    "bloomLevel": {
      "type": "string",
      "enum": ["REMEMBER", "UNDERSTAND", "APPLY", "ANALYZE", "EVALUATE"]
    },
    "conceptTags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" }
    },
    "status": { "type": "string", "const": "PUBLISHED" }
  }
}
